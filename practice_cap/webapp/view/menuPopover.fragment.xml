<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <ActionSheet id="actionSheet"
        xmlns="sap.m"
        xmlns:core="sap.ui.core" 
        core:require="{ MessageToast: 'sap/m/MessageToast' }"
         showCancelButton="true" placement="Bottom">
        <Button text="{i18n>btnSettings}" icon="sap-icon://action-settings" press="onPressSetting" />
        <Button text="{i18n>btnLogout}" icon="sap-icon://log" press="onPressLogOut" />
        
 
       
    </ActionSheet>
</core:FragmentDefinition>