<mvc:View
    controllerName="app.practicecap.controller.DashBoard"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:u="sap.uxap"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
>
    <Page
        showHeader="true"
        enableScrolling="false"
        titleAlignment="Center"
        showFooter="false"
    
    
    >
        <customHeader>
            <Bar>
                <contentLeft>
                    <Image
                        src="images/logo.jpg"
                        alt="Logo"
                        height="40px"
                    />
                </contentLeft>
                <contentMiddle>
                    <!-- Add middle content if required -->
                </contentMiddle>
                <contentRight>
                    <Button
                        icon="sap-icon://hint"
                        type="Transparent"
                    />
                    <Button
                        icon="sap-icon://bell"
                        type="Transparent"
                        press="handleResponsivePopoverPress"
                        ariaHasPopup="Dialog"
                    />
                    <Avatar
                        initials="P"
                        displaySize="XS"
                        press="menuPopover"
                        ariaHasPopup="Dialog"
                    />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <u:ObjectPageLayout
                id="Dashboard"
                showHeaderContent="false"
                class="dashboard"
            >
                <u:sections>
                    

                    <!-- Master Data Section -->
                    <u:ObjectPageSection
                        titleUppercase="false"
                        title="{dashboard>/masterData/title}"
                    >
                        <u:subSections>
                            <u:ObjectPageSubSection titleUppercase="false">
                                <f:GridContainer
                                    items="{dashboard>/masterData/items}"
                                >
                                    <f:layout>
                                        <f:GridContainerSettings
                                            rowSize="55px"
                                            columnSize="84px"
                                            gap="12px"
                                        />
                                    </f:layout>
                                    <f:layoutXS>
                                        <f:GridContainerSettings
                                            rowSize="45px"
                                            columnSize="70px"
                                            gap="12px"
                                        />
                                    </f:layoutXS>
                                    <GenericTile
                                        header="{dashboard>header}"
                                        press="onPressManageCustomer"
                                        subheader="{dashboard>subHeader}"
                                        app:route="{dashboard>route}"
                                        app:key="{dashboard>key}"
                                    >
                                        <layoutData>
                                            <f:GridContainerItemLayoutData
                                                minRows="2"
                                                columns="2"
                                            />
                                        </layoutData>
                                        <TileContent
                                            busy="{dashboard>state}"
                                            footer="{dashboard>footer}"
                                        >
                                            <NumericContent
                                                value="{dashboard>value}"
                                                icon="{dashboard>icon}"
                                                withMargin="false"
                                            />
                                        </TileContent>
                                    </GenericTile>
                                </f:GridContainer>
                            </u:ObjectPageSubSection>
                        </u:subSections>
                    </u:ObjectPageSection>

                    <!-- Sample Section -->
                    <u:ObjectPageSection
                        titleUppercase="false"
                        title="{dashboard>/Sample/title}"
                    >
                        <u:subSections>
                            <u:ObjectPageSubSection titleUppercase="false">
                                <f:GridContainer
                                    items="{dashboard>/Sample/items}"
                                >
                                    <f:layout>
                                        <f:GridContainerSettings
                                            rowSize="55px"
                                            columnSize="84px"
                                            gap="12px"
                                        />
                                    </f:layout>
                                    <f:layoutXS>
                                        <f:GridContainerSettings
                                            rowSize="45px"
                                            columnSize="70px"
                                            gap="12px"
                                        />
                                    </f:layoutXS>
                                    <GenericTile
                                        header="{dashboard>header}"
                                        press="onSamplePress"
                                        subheader="{dashboard>subHeader}"
                                        app:route="Sample"
                                        app:key="{dashboard>key}"
                                    >
                                        <layoutData>
                                            <f:GridContainerItemLayoutData
                                                minRows="2"
                                                columns="2"
                                            />
                                        </layoutData>
                                        <TileContent
                                            busy="{dashboard>state}"
                                            footer="{dashboard>footer}"
                                        >
                                            <NumericContent
                                                value="{dashboard>value}"
                                                icon="{dashboard>icon}"
                                                withMargin="false"
                                            />
                                        </TileContent>
                                    </GenericTile>
                                </f:GridContainer>
                            </u:ObjectPageSubSection>
                        </u:subSections>
                    </u:ObjectPageSection>
                </u:sections>
            </u:ObjectPageLayout>
        </content>
    </Page>
</mvc:View>
